# ═══════════════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno requeridas para ejecutar el backend
# Copiar a .env y llenar con valores reales. NUNCA commitear .env
# ═══════════════════════════════════════════════════════════════════════════

ENVIRONMENT=development
EXPECTED_DATABASE=icaro_dev

# ── Django ────────────────────────────────────────────────────────────────
SECRET_KEY=
DEBUG=True

# ── Base de datos (Neon PostgreSQL) ───────────────────────────────────────
DATABASE_URL=

# ── Cifrado de campos sensibles ───────────────────────────────────────────
FIELD_ENCRYPTION_KEY=

# ── Storage (Cloudflare R2 o AWS S3) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# CORS_ALLOWED_ORIGINS=https://app.icaro.com,https://www.icaro.com

