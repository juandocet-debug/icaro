# .env.production.example
# Variables OBLIGATORIAS para el despliegue en Producción (Railway / Vercel / Cloudflare R2)

# --- Entorno Base ---
ENVIRONMENT=production
SECRET_KEY=cambiar_por_una_llave_secreta_fuerte
FIELD_ENCRYPTION_KEY=llave_simetrica_fuerte_base64
EXPECTED_DATABASE=icaro_prod
DATABASE_URL=postgres://user:password@host.region.aws.neon.tech/icaro_prod?sslmode=require

# Integraciones server-to-server
# Debe coincidir con ICARO_API_TOKEN en DOXA. No exponer al frontend.
DOXA_SERVICE_TOKEN=
PORT=8000

# --- Almacenamiento Cloudflare R2 / AWS S3 ---
AWS_ACCESS_KEY_ID=tu_access_key
AWS_SECRET_ACCESS_KEY=tu_secret_key
AWS_STORAGE_BUCKET_NAME=icaro-archivos-prod
AWS_S3_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
AWS_S3_REGION_NAME=us-east-1

# --- Red / Seguridad ---
# Lista de dominios permitidos para alojar/servir la app (separado por comas)
ALLOWED_HOSTS=.up.railway.app,icaro-production.up.railway.app,localhost,127.0.0.1
# Lista separada por comas de los orígenes de frontend autorizados
CORS_ALLOWED_ORIGINS=https://tu-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://tu-frontend.vercel.app

# --- Caché Compartida (Recomendado Redis para Rate Limiting en Multi-Instancia) ---
# Ej: rediss://:password@host:port
CACHE_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

