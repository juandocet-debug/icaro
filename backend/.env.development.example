# Plantilla de variables para el entorno de desarrollo local
ENVIRONMENT=development
EXPECTED_DATABASE=icaro_dev

# NOTA: Debes colocar aquí la URL de conexión a tu base de datos icaro_dev en Neon
DATABASE_URL=postgres://user:password@endpoint-pooler.neon.tech/icaro_dev?sslmode=require

SECRET_KEY=django-insecure-dev-key-do-not-use-in-prod
DEBUG=True
FIELD_ENCRYPTION_KEY=dev-encryption-key
